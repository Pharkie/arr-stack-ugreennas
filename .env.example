# Domain Configuration
# Use a domain managed by Cloudflare (for automatic SSL certificates via DNS challenge)
# Example: yourdomain.com or a cheap domain like yourname-nas.com
DOMAIN=yourdomain.com

# Cloudflare Configuration (for SSL/TLS certificates)
# Generate API token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone:DNS:Edit, Zone:Zone:Read for the domain
CF_DNS_API_TOKEN=your_cloudflare_api_token_here

# Cloudflare Tunnel Token (for external access without port forwarding)
# Get from: https://one.dash.cloudflare.com/ → Networks → Tunnels → Create/Configure
# Only required if using Cloudflare Tunnel (recommended for CGNAT/no port forwarding)
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Surfshark VPN Credentials (WireGuard)
# Get credentials from: https://my.surfshark.com/ → VPN → Manual Setup → Router → WireGuard
# 1. Select "I don't have a key pair" to generate new keys
# 2. Click "Download" to get the full WireGuard configuration file
# 3. Open the downloaded .conf file and extract:
#    - PrivateKey (from [Interface] section)
#    - Address (from [Interface] section, e.g., 10.14.0.2/16)
SURFSHARK_PRIVATE_KEY=your_wireguard_private_key_here
SURFSHARK_WG_ADDRESS=10.14.0.2/16

# VPN Configuration (optional)
# Comma-separated list of countries (default: Netherlands)
VPN_COUNTRIES=Netherlands,Germany,Switzerland

# Static IP Addresses (traefik-proxy network: 192.168.100.0/24)
GLUETUN_IP=192.168.100.3
JELLYFIN_IP=192.168.100.4
PIHOLE_IP=192.168.100.5
WG_IP=192.168.100.6
HOMARR_IP=192.168.100.7

# Pi-hole Admin Password
# Choose a strong password for the Pi-hole web interface
PIHOLE_UI_PASS=your_secure_pihole_password

# WireGuard Password Hash
# Generate with: docker run -it ghcr.io/wg-easy/wg-easy wgpw 'YOUR_PASSWORD'
# Or use online bcrypt generator: https://bcrypt-generator.com/ (use cost factor 10-12)
WG_PASSWORD_HASH=your_bcrypt_password_hash_here

# Traefik Dashboard Authentication
# Generate with: echo $(htpasswd -nb admin your_password) | sed -e s/\\$/\\$\\$/g
# Or use online generator: https://hostingcanada.org/htpasswd-generator/
# Note: Dollar signs ($) must be escaped as $$ in docker-compose
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$generated$$hash

# Homarr Encryption Key
# Generate with: openssl rand -hex 32
# Used to encrypt sensitive data in Homarr dashboard
HOMARR_ENCRYPTION_KEY=your_64_character_hex_key_here

# Optional: PUID/PGID (default: 1000/1000)
# Find your user ID with: id -u
# Find your group ID with: id -g
# PUID=1000
# PGID=1000

# Optional: Timezone (default: Europe/London)
# TZ=Europe/London
